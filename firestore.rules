rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\- &()]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // 1. Products Collection Rules
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isValidId(productId) &&
                   incoming().id is string &&
                   incoming().name is string &&
                   incoming().nameMr is string &&
                   incoming().image is string &&
                   incoming().description is string &&
                   incoming().price is number &&
                   incoming().price >= 0 &&
                   incoming().status in ['Available', 'Out of Stock'];
      allow delete: if isValidId(productId);
    }

    // 2. Employees Collection Rules
    match /employees/{employeeId} {
      allow read: if true;
      allow create, update: if isValidId(employeeId) &&
                   incoming().id is string &&
                   incoming().fullName is string &&
                   incoming().email is string &&
                   incoming().mobile is string &&
                   incoming().department is string &&
                   incoming().designation is string &&
                   incoming().username is string &&
                   incoming().password is string;
      allow delete: if isValidId(employeeId);
    }

    // 3. Attendance Records Rules
    match /attendance/{attendanceId} {
      allow read: if true;
      allow create, update: if isValidId(attendanceId) &&
                   incoming().id is string &&
                   incoming().employeeId is string &&
                   incoming().employeeName is string &&
                   incoming().department is string &&
                   incoming().date is string &&
                   incoming().punchIn is string;
      allow delete: if isValidId(attendanceId);
    }

    // 4. Leave Requests Rules
    match /leaves/{leaveId} {
      allow read: if true;
      allow create, update: if isValidId(leaveId) &&
                   incoming().id is string &&
                   incoming().employeeId is string &&
                   incoming().employeeName is string &&
                   incoming().leaveType is string &&
                   incoming().reason is string &&
                   incoming().fromDate is string &&
                   incoming().toDate is string &&
                   incoming().status in ['Pending', 'Approved', 'Rejected'];
      allow delete: if isValidId(leaveId);
    }

    // 5. End Of Day Reports Rules
    match /eod_reports/{reportId} {
      allow read: if true;
      allow create, update: if isValidId(reportId) &&
                   incoming().id is string &&
                   incoming().employeeId is string &&
                   incoming().employeeName is string &&
                   incoming().department is string &&
                   incoming().date is string &&
                   incoming().answers is list &&
                   incoming().submittedAt is string;
      allow delete: if isValidId(reportId);
    }

    // 6. Department Configs Rules
    match /department_configs/{configId} {
      allow read: if true;
      allow create, update: if isValidId(configId) &&
                   incoming().id is string &&
                   incoming().questions is list;
      allow delete: if isValidId(configId);
    }

    // 7. Contact Inquiries Rules
    match /contact_queries/{queryId} {
      allow read: if true;
      allow create, update: if isValidId(queryId) &&
                    incoming().id is string &&
                    incoming().fullName is string &&
                    incoming().mobile is string &&
                    incoming().message is string &&
                    incoming().submittedAt is string;
      allow delete: if isValidId(queryId);
    }

    // 8. Dealer Inquiries Rules
    match /dealer_queries/{dealerId} {
      allow read: if true;
      allow create, update: if isValidId(dealerId) &&
                    incoming().id is string &&
                    incoming().fullName is string &&
                    incoming().mobile is string &&
                    incoming().address is string &&
                    incoming().district is string &&
                    incoming().state is string &&
                    incoming().status in ['Pending', 'Approved', 'Rejected'] &&
                    incoming().submittedAt is string;
      allow delete: if isValidId(dealerId);
    }

    // 9. Farmer Feedbacks / Testimonials Rules
    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create, update: if isValidId(feedbackId) &&
                    incoming().id is string &&
                    incoming().fullName is string &&
                    incoming().rating is number &&
                    incoming().rating >= 1 &&
                    incoming().rating <= 5 &&
                    incoming().review is string &&
                    incoming().submittedAt is string;
      allow delete: if isValidId(feedbackId);
    }

    // 10. configs (About Us etc) Rules
    match /configs/{configId} {
      allow read: if true;
      allow create, update: if isValidId(configId) &&
                   incoming().story is string &&
                   incoming().storyMr is string &&
                   incoming().mission is string &&
                   incoming().missionMr is string &&
                   incoming().vision is string &&
                   incoming().visionMr is string;
      allow delete: if isValidId(configId);
    }

    // 11. Jobs Collection Rules
    match /jobs/{jobId} {
      allow read: if true;
      allow create, update: if isValidId(jobId) &&
                   incoming().id is string &&
                   incoming().title is string &&
                   incoming().description is string &&
                   incoming().workingTime is string &&
                   incoming().type is string;
      allow delete: if isValidId(jobId);
    }

    // 12. Career Applications Collection Rules
    match /career_applications/{appId} {
      allow read: if true;
      allow create, update: if isValidId(appId) &&
                   incoming().id is string &&
                   incoming().jobId is string &&
                   incoming().jobTitle is string &&
                   incoming().fullName is string &&
                   incoming().village is string &&
                   incoming().mobile is string &&
                   incoming().email is string &&
                   incoming().gender is string;
      allow delete: if isValidId(appId);
    }

  }
}
